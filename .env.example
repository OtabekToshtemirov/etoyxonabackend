# Application
APP_PORT=4000
APP_ENV=development
APP_NAME=iToyxona API
APP_URL=http://localhost:4000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=itoyxona

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-in-production
JWT_REFRESH_EXPIRES_IN=7d

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=itoyxona

# SMS (Eskiz.uz)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_SENDER=4546
SMS_MODE=mock
# SMS_MODE=mock (test) yoki SMS_MODE=production (haqiqiy yuborish)

# CBU Exchange Rate API
CBU_API_URL=https://cbu.uz/oz/arkhiv-kursov-valyut/json

# ─── To'lov integratsiyalari ─────────────────────
# Payme/Click/Uzum kalitlari ENDI har bir venue uchun ALOHIDA.
# To'yxona egasi Settings sahifasidan o'z merchant kalitlarini kiritadi.
# Pul to'g'ridan-to'g'ri shu to'yxonaning hisobiga tushadi.
# 
# Global .env da kalit KERAK EMAS — database'da venue_payment_settings jadvalida saqlanadi.
